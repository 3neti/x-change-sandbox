{
    "name": "3neti/x-change",
    "description": "X-Change API-first financial product platform for onboarding, wallet, pricing, Pay Code issuance, and redemption workflows.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lester B. Hurtado"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "/Users/rli/PhpstormProjects/packages/voucher",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "3neti/contact": "^1.1",
        "3neti/instruction": "^0.2",
        "3neti/laravel-model-channel": "^1.1",
        "3neti/money-issuer": "^1.0",
        "3neti/voucher": "dev-main",
        "illuminate/contracts": "^13.0",
        "illuminate/events": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-data": "^4.21"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "LBHurtado\\XChange\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\XChange\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\XChange\\Providers\\XChangeServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "test:unit": "pest",
        "test:coverage": "pest --coverage"
    }
}
