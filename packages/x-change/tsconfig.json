{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "vite.config.ts",
        "vitest.config.ts",
        "resources/js/**/*.ts",
        "resources/js/**/*.vue",
        "resources/js/**/*.d.ts"
    ]
}
