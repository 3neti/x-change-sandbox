{
    "name": "3neti/x-change",
    "description": "Programmable Disbursement Infrastructure (PDI) platform for banks and EMIs. API-first engine for KYC-gated, wallet-backed Pay Code issuance, claim, redemption, and disbursement workflows.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "programmable disbursement",
        "pay code",
        "voucher",
        "fintech",
        "banking",
        "wallet",
        "kyc",
        "emi",
        "payments",
        "disbursement",
        "claim",
        "redemption",
        "financial infrastructure",
        "api-first"
    ],
    "homepage": "https://3neti.com/x-change",
    "support": {
        "email": "licensing@3neti.com"
    },
    "authors": [
        {
            "name": "Lester B. Hurtado",
            "role": "Creator"
        }
    ],
    "type": "library",

    "repositories": [
        {
            "type": "path",
            "url": "/Users/rli/PhpstormProjects/packages/voucher",
            "options": {
                "symlink": true
            }
        }
    ],

    "require": {
        "php": "^8.2",
        "3neti/contact": "^1.1",
        "3neti/instruction": "^0.2",
        "3neti/laravel-model-channel": "^1.1",
        "3neti/money-issuer": "^1.0",
        "3neti/report-registry": "^1.1",
        "3neti/voucher": "dev-main",
        "brick/money": "^0.10.3",
        "illuminate/contracts": "^13.0",
        "illuminate/events": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-data": "^4.21"
    },

    "require-dev": {
        "dedoc/scramble": "^0.13.20",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },

    "autoload": {
        "psr-4": {
            "LBHurtado\\XChange\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\XChange\\Tests\\": "tests/"
        }
    },

    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\XChange\\Providers\\XChangeServiceProvider"
            ]
        }
    },

    "minimum-stability": "dev",
    "prefer-stable": true,

    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },

    "scripts": {
        "test": "pest",
        "test:unit": "pest",
        "test:coverage": "pest --coverage"
    }
}
